universe = vanilla
executable = run_job.sh

arguments = $(ProcId)

output = logs/job_Muons_2023D_Pveto_$(ProcId).out
error  = logs/job_Muons_2023D_Pveto_$(ProcId).err
log    = logs/job_Muons_2023D_Pveto_$(ProcId).log

request_cpus = 1
request_memory = 4GB
request_disk = 2GB

should_transfer_files = YES
when_to_transfer_output = ON_EXIT

transfer_input_files = muonBackgroundEstimateFromNtuples.py, filelist_2023D_Muons.txt, helper_functions.py, python_env

queue 24